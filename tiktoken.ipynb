   "source": [
    "# Using the tiktoken library."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "3a123682",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "[25216, 495, 382, 265, 1776, 493]"
      ]
     },
     "execution_count": 2,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "import tiktoken\n",
    "encoding = tiktoken.encoding_for_model(\"gpt-4.1-mini\")\n",
    "token  = encoding.encode(\"Hey this is sushant\")\n",
    "token"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "716c251a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hey\n",
      " this\n",
      " is\n",
      " s\n",
      "ush\n",
      "ant\n"
     ]
    }
   ],
   "source": [
    "for tokens in token:\n",
    "    d = encoding.decode([tokens])\n",
    "    print(d)\n",
    "    "
   ]
  }
 ],
